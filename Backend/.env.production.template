# Production Environment Template
# Copy this to .env.production and fill in actual values

# Core
NODE_ENV=production
PORT=8080

# Database (MongoDB Atlas recommended for production)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/senses?retryWrites=true&w=majority

# Security
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long

# AI Services
OPENAI_API_KEY=sk-proj-your-actual-openai-key
AI_MODEL=gpt-4o-mini
EMBED_MODEL=text-embedding-3-large

# User ingestion (LinkedIn/PDF)
TAVILY_API_KEY=your-tavily-api-key

# Stripe (if using payments)
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Frontend URL (comma-separated for multiple domains)
FRONTEND_URL=https://yourdomain.com,https://www.yourdomain.com

# Feature Flags
RATE_LIMIT_ENABLED=true
TRUST_SCORE_ENABLED=true
DUELS_ENABLED=true

# Rate Limiting
RATE_LIMIT_PER_MIN=60
